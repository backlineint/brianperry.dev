---
import RadHero from '../components/RadHero.astro';

import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

// 1. Generate a new path for every collection entry
export async function getStaticPaths() {
  const jamsEntries = await getCollection('jams');
  return jamsEntries.map(entry => ({
    params: { slug: `jams/${entry.slug}` }, props: { entry },
  }));
}

// 2. When it's time to render, you can get the entry directly from the prop
const { entry } = Astro.props;
const { Content } = await entry.render();
const imagePath = entry.data.imagePath ? `/images/${entry.data.imagePath}` : '';

const mainContentClasses = imagePath ? 'main-content with-image' : 'main-content no-image';
---

<Layout title={entry.data.title}>
    <main>
      <RadHero
        title={entry.data.title}
        imgSrc={imagePath}
        imgAlt={entry.data.title}
      />
      <div class={mainContentClasses}>
        <aside>
          <p class="post-date">Content aging process began: {entry.data.date.toDateString()}</p>
          <p class="description">{entry.data.description}</p>
          <!-- Feature: resources -->
        </aside>
        <article>
          <Content />
        </article>
      </div>
    </main>
</Layout>
<style is:global>
  main {
    max-width: var(--size-lg);
    margin: 0 auto;
  }
  .rad main {
    margin: 0 var(--default-padding);
    @media (min-width: 768px) {
      margin: 0 var(--size-8);
    }
    @media (min-width: 1100px) {
        margin: 0 auto;
    }
  }
  .main-content {
    margin: 0 var(--default-padding);
    @media (min-width: 1024px) {
      display: grid;
      grid-template-columns: 5fr 2fr;
      margin: 0 auto;
      padding: 0 var(--default-padding);
      grid-gap: var(--default-padding);
    }
  }
  .rad .main-content.with-image {
    @media (min-width: 1024px) {
      position: relative;
      top: calc(var(--size-9) * -1);
      left: var(--size-7);
    }
  }
  .rad .main-content.no-image {
    @media (min-width: 1024px) {
      position: relative;
      top: var(--size-7);
    }
  }
  article {
    width: fit-content;
    margin: 0 auto;
    padding-bottom: var(--size-5);
    @media (min-width: 1024px) {
      order: 1;
      margin: var(--size-5) 0
    }
  }
  .rad article {
    margin: var(--size-5) calc(var(--default-padding) * -1);
    padding:var(--default-padding);
    background-color: var(--surface-2);
    box-shadow: var(--shadow-5);
    border: var(--border-size-2) solid var(--cyan-3);
    @media (min-width: 1024px) {
      margin: var(--size-5) auto;
    }
  }
  .rad article img {
    border: 4px dotted var(--pink-6);
    transform: rotate(1deg);
  }
  aside {
    height: fit-content;
    margin: var(--size-5) calc(var(--default-padding) * -1);
    padding:var(--default-padding);
    background-color: var(--surface-2);
    @media (min-width: 1024px) {
      order: 2;
      margin: var(--size-5) 0;
    }
  }
  .rad aside {
    height: unset;
    background-color: var(--surface-2);
    box-shadow: var(--shadow-5);
    @media (min-width: 1024px) {
      margin-top: 0;
      background-color: unset;
      box-shadow: unset;
    }
  }
  .rad aside .post-date {
    @media (min-width: 1024px) {
      padding: 2rem;
      border-radius: var(--radius-blob-1);
      background-color: var(--surface-2);
      border: 3px solid var(--purple-6);
      box-shadow: var(--shadow-5);
    }
  }
  .rad aside .description {
    @media (min-width: 1024px) {
      position: sticky;
      top: 6rem;
      padding: 2rem;
      background-color: var(--surface-2);
      border: 2px solid var(--yellow-3);
      box-shadow: var(--shadow-5);
      border-radius: 10px;
      font-weight: var(--font-weight-6);
    }
  }
  
