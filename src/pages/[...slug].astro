---
import RadHero from '../components/RadHero.astro';

import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

// 1. Generate a new path for every collection entry
export async function getStaticPaths() {
  const jamsEntries = await getCollection('jams');
  return jamsEntries.map(entry => ({
    params: { slug: `jams/${entry.slug}` }, props: { entry },
  }));
}

// 2. When it's time to render, you can get the entry directly from the prop
const { entry } = Astro.props;
const { Content } = await entry.render();
const imagePath = entry.data.imagePath ? `/images/${entry.data.imagePath}` : '';
---

<Layout title={entry.data.title}>
    <main>
      <RadHero
        title={entry.data.title}
        imgSrc={imagePath}
        imgAlt={entry.data.title}
      />
      <div class="main-content">
        <aside>
          <p>Content aging process began: {entry.data.date.toDateString()}</p>
          <h5>{entry.data.description}</h5>
          <!-- Feature: resources -->
        </aside>
        <article>
          <Content />
        </article>
      </div>
    </main>
</Layout>
<style is:global>
  main {
    max-width: var(--size-lg);
    margin: 0 auto;
  }
  .rad main {
    margin: 0 var(--default-padding);
    @media (min-width: 768px) {
      margin: 0 var(--size-8);
    }
    @media (min-width: 1100px) {
        margin: 0 auto;
    }
  }
  .main-content {
    margin: 0 var(--default-padding);
    @media (min-width: 1024px) {
      margin: 0 auto;
      padding: 0 var(--default-padding);
    }
  }
  aside {
    background-color: var(--surface-2);
    margin: var(--size-5) calc(var(--default-padding) * -1);
    padding:var(--default-padding);
  }
  article {
    padding-bottom: var(--size-5);
    /* background-color: var(--surface-2);
    border-radius: var(--radius-3);
    padding:var(--default-padding); */
  }
