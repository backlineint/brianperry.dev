---
import getSortedCollection from "../lib/getSortedCollection";
import Layout from '../layouts/Layout.astro';

const entries = await getSortedCollection('jams');
---

<Layout title="Jams">
	<main>
		<h1>Jams</h1>
		{
			entries.map((entry) => (
				<p><a href={"/jams/" + entry['slug']}>{entry['data']['title']}</a></p>
			))
		}
	</main>
</Layout>

<style>
	main {
		margin: auto;
		padding: 1.5rem;
		max-width: 60ch;
	}
</style>
