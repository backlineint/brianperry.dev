---
import BaseHead from "../../components/BaseHead.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import Stars from "../../components/Stars.astro";
import StickerCard from "../../components/StickerCard.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../../consts";

import { getSortedPosts } from "../../lib/getSortedPosts";

const posts = await getSortedPosts();
const total = posts.length;
const duos = [1, 3, 2, 4, 6, 5];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Posts - ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Stars />
    <Header />
    <header class="hero">
      <span class="eyebrow">// the full backlog</span>
      <h1>All <span class="pink">Posts</span></h1>
      <p class="bio">
        Code, AI experiments, Drupal, game reviews, and the occasional record I
        won't shut up about.
        <span class="mono count">{total} entries</span>
      </p>
    </header>

    <main>
      <div class="mosaic">
        {
          posts.map((post, i) => (
            <StickerCard
              post={post}
              ep={total - i}
              duo={duos[i % duos.length]}
              featured={i === 0}
            />
          ))
        }
      </div>
    </main>
    <Footer />
    <style>
      .hero {
        max-width: 1080px;
        margin: 0 auto;
        padding: 36px 18px 0;
        text-align: center;
        position: relative;
      }
      .eyebrow {
        font-family: "JetBrains Mono", monospace;
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--cyan);
      }
      .hero h1 {
        font-size: 64px;
        line-height: 0.92;
        letter-spacing: -0.035em;
        margin: 16px 0 0;
        max-inline-size: none;
        text-transform: uppercase;
      }
      .bio {
        max-width: 620px;
        margin: 16px auto 0;
        color: var(--muted);
        font-size: 18px;
        line-height: 1.6;
        text-wrap: pretty;
      }
      .count {
        display: block;
        margin-top: 6px;
        color: var(--gold);
        font-size: 14px;
        letter-spacing: 0.04em;
      }
      main {
        margin-top: 40px;
      }
      @media (max-width: 720px) {
        .hero h1 {
          font-size: 44px;
        }
      }
    </style>
  </body>
</html>
