---
import BaseHead from "../../components/BaseHead.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import Stars from "../../components/Stars.astro";
import StickerCard from "../../components/StickerCard.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../../consts";

import { getSortedPosts } from "../../lib/getSortedPosts";

const posts = await getSortedPosts();
const total = posts.length;
const duos = [1, 3, 2, 4, 6, 5];
// How many cards are visible before infinite-scroll reveals more.
const INITIAL = 9;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Posts - ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Stars />
    <Header />
    <header class="hero">
      <span class="eyebrow">// the full backlog</span>
      <h1>All <span class="pink">Posts</span></h1>
      <p class="bio">
        Code, AI experiments, Drupal, game reviews, and the occasional record I
        won't shut up about.
        <span class="mono count">{total} entries</span>
      </p>
    </header>

    <main>
      <div class="mosaic" data-infinite>
        {
          posts.map((post, i) => (
            <StickerCard
              post={post}
              duo={duos[i % duos.length]}
              featured={i === 0}
              deferred={i >= INITIAL}
            />
          ))
        }
      </div>
      <noscript>
        <style>.scard.is-deferred { display: flex !important; }</style>
      </noscript>
      <div class="feed-sentinel" data-feed-sentinel aria-hidden="true"></div>
    </main>

    <script>
      function initInfiniteFeed() {
        const mosaic = document.querySelector("[data-infinite]");
        const sentinel = document.querySelector("[data-feed-sentinel]");
        if (!mosaic || !sentinel || mosaic.hasAttribute("data-feed-ready"))
          return;
        mosaic.setAttribute("data-feed-ready", "");

        const BATCH = 6;
        const revealNext = () => {
          const hidden = mosaic.querySelectorAll(".scard.is-deferred");
          const n = Math.min(BATCH, hidden.length);
          for (let i = 0; i < n; i++) hidden[i].classList.remove("is-deferred");
          return hidden.length - n;
        };

        // No IntersectionObserver — just show everything.
        if (!("IntersectionObserver" in window)) {
          mosaic
            .querySelectorAll(".scard.is-deferred")
            .forEach((c) => c.classList.remove("is-deferred"));
          sentinel.remove();
          return;
        }

        const near = () =>
          sentinel.getBoundingClientRect().top < window.innerHeight + 800;

        const io = new IntersectionObserver(
          (entries) => {
            if (!entries.some((e) => e.isIntersecting)) return;
            let remaining = revealNext();
            // Keep filling while the sentinel is still within the preload zone.
            while (remaining > 0 && near()) remaining = revealNext();
            if (remaining <= 0) {
              io.disconnect();
              sentinel.remove();
            }
          },
          { rootMargin: "800px 0px" },
        );
        io.observe(sentinel);
      }

      if (document.readyState !== "loading") initInfiniteFeed();
      else document.addEventListener("DOMContentLoaded", initInfiniteFeed);
      document.addEventListener("astro:page-load", initInfiniteFeed);
    </script>
    <Footer />
    <style>
      .hero {
        max-width: 1080px;
        margin: 0 auto;
        padding: 36px 18px 0;
        text-align: center;
        position: relative;
      }
      .eyebrow {
        font-family: "JetBrains Mono", monospace;
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--cyan);
      }
      .hero h1 {
        font-size: 64px;
        line-height: 0.92;
        letter-spacing: -0.035em;
        margin: 16px 0 0;
        max-inline-size: none;
        text-transform: uppercase;
      }
      .bio {
        max-width: 620px;
        margin: 16px auto 0;
        color: var(--muted);
        font-size: 18px;
        line-height: 1.6;
        text-wrap: pretty;
      }
      .count {
        display: block;
        margin-top: 6px;
        color: var(--gold);
        font-size: 14px;
        letter-spacing: 0.04em;
      }
      main {
        margin-top: 40px;
      }
      .feed-sentinel {
        height: 1px;
      }
      @media (max-width: 720px) {
        .hero h1 {
          font-size: 44px;
        }
      }
    </style>
  </body>
</html>
