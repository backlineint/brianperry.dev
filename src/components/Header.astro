---
import HeaderLink from "./HeaderLink.astro";
---

<header>
  <nav class="nav">
    <a class="brand" href="/">brian<span class="mid">perry</span>.dev<span class="caret" aria-hidden="true">_</span></a>
    <div class="links">
      <HeaderLink href="/posts">Posts</HeaderLink>
      <HeaderLink href="/about">About</HeaderLink>
    </div>
    <div class="ico">
      <button type="button" class="theme-toggle" data-theme-toggle aria-label="Switch color theme (auto, light, dark)">
        <svg class="i-auto" viewBox="0 0 24 24" aria-hidden="true">
          <circle cx="12" cy="12" r="9" fill="none" stroke="currentColor" stroke-width="2"></circle>
          <path fill="currentColor" d="M12 3a9 9 0 0 0 0 18z"></path>
        </svg>
        <svg class="i-sun" viewBox="0 0 24 24" aria-hidden="true" fill="none">
          <circle cx="12" cy="12" r="4.2" fill="currentColor"></circle>
          <g stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <line x1="12" y1="2" x2="12" y2="4.4"></line>
            <line x1="12" y1="19.6" x2="12" y2="22"></line>
            <line x1="2" y1="12" x2="4.4" y2="12"></line>
            <line x1="19.6" y1="12" x2="22" y2="12"></line>
            <line x1="4.9" y1="4.9" x2="6.6" y2="6.6"></line>
            <line x1="17.4" y1="17.4" x2="19.1" y2="19.1"></line>
            <line x1="4.9" y1="19.1" x2="6.6" y2="17.4"></line>
            <line x1="17.4" y1="6.6" x2="19.1" y2="4.9"></line>
          </g>
        </svg>
        <svg class="i-moon" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
      </button>
      <span class="divider" aria-hidden="true"></span>
      <a href="https://bsky.app/profile/brianperry.dev" target="_blank">
        <span class="sr-only">Follow me on Bluesky</span>
        <svg xmlns="http://www.w3.org/2000/svg" aria-hidden="true" viewBox="0 0 576 512"><path fill="currentColor" d="M407.8 294.7c-3.3-.4-6.7-.8-10-1.3c3.4.4 6.7.9 10 1.3M288 227.1c-26.1-50.7-97.1-145.2-163.1-191.8C61.6-9.4 37.5-1.7 21.6 5.5C3.3 13.8 0 41.9 0 58.4S9.1 194 15 213.9c19.5 65.7 89.1 87.9 153.2 80.7c3.3-.5 6.6-.9 10-1.4c-3.3.5-6.6 1-10 1.4c-93.9 14-177.3 48.2-67.9 169.9C220.6 589.1 265.1 437.8 288 361.1c22.9 76.7 49.2 222.5 185.6 103.4c102.4-103.4 28.1-156-65.8-169.9c-3.3-.4-6.7-.8-10-1.3c3.4.4 6.7.9 10 1.3c64.1 7.1 133.6-15.1 153.2-80.7C566.9 194 576 75 576 58.4s-3.3-44.7-21.6-52.9c-15.8-7.1-40-14.9-103.2 29.8C385.1 81.9 314.1 176.4 288 227.1"/></svg>
      </a>
      <a href="https://github.com/backlineint" target="_blank">
        <span class="sr-only">My GitHub profile</span>
        <svg viewBox="0 0 16 16" aria-hidden="true"><path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"></path></svg>
      </a>
      <a href="/feed.xml">
        <span class="sr-only">RSS feed</span>
        <svg viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M5 19a2 2 0 1 0 0-4 2 2 0 0 0 0 4ZM3 9.5V13c4.4 0 8 3.6 8 8h3.5C14.5 14.6 9.4 9.5 3 9.5Zm0-6V7c7.7 0 14 6.3 14 14h3.5C20.5 11.6 12.4 3.5 3 3.5Z"></path></svg>
      </a>
    </div>
  </nav>
</header>
<style>
  header {
    position: relative;
    z-index: 3;
  }
  .nav {
    max-width: 1080px;
    margin: 0 auto;
    padding: 24px var(--page-gutter);
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 16px;
  }
  .links {
    justify-self: center;
  }
  .ico {
    justify-self: end;
  }
  .brand {
    font-family: "Archivo Black", sans-serif;
    font-size: 18px;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: var(--ink);
    text-decoration: none;
  }
  .brand:hover {
    text-decoration: none;
    color: var(--ink);
  }
  .brand .mid {
    color: var(--red);
  }
  .brand .caret {
    color: var(--cyan);
    margin-left: 0.04em;
  }
  .links {
    display: flex;
    gap: 16px;
    align-items: center;
  }
  .ico {
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .ico .divider {
    flex: 0 0 auto;
    width: 2px;
    height: 22px;
    border-radius: 1px;
    background: var(--line);
  }
  .ico a,
  .ico button {
    width: 34px;
    height: 34px;
    border-radius: 8px;
    background: var(--surface);
    border: 0;
    margin: 0;
    padding: 0;
    cursor: pointer;
    color: inherit;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s;
  }
  .ico a:hover,
  .ico button:hover {
    background: var(--surface-2);
  }
  .ico svg {
    width: 17px;
    height: 17px;
    fill: var(--cyan);
    color: var(--cyan);
  }
  /* Mid widths: the centered grid forces symmetric side columns and the
     wordmark outgrows its column (~620px). Drop to a single space-between row. */
  @media (max-width: 720px) {
    .nav {
      display: flex;
      justify-content: space-between;
      padding-bottom: 0;
    }
  }
  /* Narrow: let the three groups wrap and center. */
  @media (max-width: 620px) {
    .nav {
      flex-wrap: wrap;
      justify-content: center;
      gap: 10px 14px;
    }
  }
</style>
