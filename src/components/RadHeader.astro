      background-image: url("/images/rad_dark.jpg");
    }
    background-size: cover;
    background-attachment: fixed;
  }

  header {
    background-color: var(--surface-2);
  }
  .rad header {
    @media (min-width: 768px) {
      position: sticky;
      top: 0;
