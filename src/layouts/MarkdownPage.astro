---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Stars from "../components/Stars.astro";
import { SITE_TITLE } from "../consts";

interface Props {
  frontmatter: {
    title: string;
    description: string;
    heroImage: string;
    alt: string;
    imageAlignment?: string;
  };
}

const { frontmatter } = Astro.props;
---

<html lang="en">
  <head>
    <BaseHead
      title={`${frontmatter.title} - ${SITE_TITLE}`}
      description={frontmatter.description}
      image={frontmatter.heroImage}
    />
  </head>

  <body class="article-page">
    <Stars />
    <Header />
    <main>
      <article class="article">
        <a href="/" class="crumb">← home</a>
        <h1>{frontmatter.title}</h1>

        {
          frontmatter.heroImage && (
            <figure class="phero">
              <img
                src={frontmatter.heroImage}
                alt={frontmatter.alt}
                class={frontmatter.imageAlignment || "center"}
              />
            </figure>
          )
        }

        <div class="prose body">
          <slot />
        </div>
      </article>
    </main>
    <Footer />
    <style>
      .article {
        max-width: 720px;
        margin: 0 auto;
        padding-top: 8px;
      }
      .crumb {
        font-family: "JetBrains Mono", monospace;
        font-size: 12px;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--faint);
        text-decoration: none;
        display: inline-block;
      }
      .crumb:hover {
        color: var(--cyan);
      }
      .article h1 {
        font-size: 54px;
        line-height: 1;
        letter-spacing: -0.03em;
        margin: 18px 0 0;
        max-inline-size: none;
        text-align: center;
        text-transform: uppercase;
      }
      .phero {
        margin: 28px 0 0;
        border: 2px solid var(--line);
        border-radius: 18px;
        overflow: hidden;
        aspect-ratio: 16 / 8;
        box-shadow: 6px 6px 0 rgba(0, 0, 0, 0.3);
        position: relative;
      }
      .phero img {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        border: 0;
        border-radius: 0;
        box-shadow: none;
      }
      .phero img.top {
        object-position: top;
      }
      .body {
        margin-top: 34px;
      }
      @media (max-width: 720px) {
        .article h1 {
          font-size: 38px;
        }
      }
    </style>
  </body>
</html>
