---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Stars from "../components/Stars.astro";
import FormattedDate from "../components/FormattedDate.astro";
import { SITE_TITLE } from "../consts";

interface Props {
  title: string;
  description?: string;
  pubDate: Date;
  updatedDate?: string;
  heroImage?: string;
  tag?: string;
}

const { title, description, pubDate, updatedDate, heroImage, tag } =
  Astro.props;
---

<html lang="en">
  <head>
    <BaseHead
      title={`${title} - ${SITE_TITLE}`}
      description={description ? description : "brianperry.dev"}
      image={heroImage}
    />
  </head>

  <body>
    <Stars />
    <Header />
    <main>
      <article class="article">
        <a href="/posts" class="crumb">← all posts</a>
        <div class="pmeta">
          {tag && <span class="badge ghost">{tag}</span>}
          <span class="mono date">
            <FormattedDate date={new Date(pubDate)} />
          </span>
        </div>
        <h1>{title}</h1>
        {
          updatedDate && (
            <p class="last-updated-on">
              Last updated on <FormattedDate date={new Date(updatedDate)} />
            </p>
          )
        }

        {
          heroImage && (
            <figure class="phero">
              <img src={heroImage} alt="" />
            </figure>
          )
        }

        <div class:list={["prose", "body", { "no-hero": !heroImage }]}>
          <slot />
        </div>
      </article>
    </main>
    <Footer />
    <style>
      .article {
        max-width: 720px;
        margin: 0 auto;
        padding-top: 8px;
      }
      .crumb {
        font-family: "JetBrains Mono", monospace;
        font-size: 12px;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--faint);
        text-decoration: none;
        display: inline-block;
      }
      .crumb:hover {
        color: var(--cyan);
      }
      .pmeta {
        display: flex;
        gap: 10px;
        align-items: center;
        margin: 26px 0 0;
        justify-content: center;
      }
      .pmeta .date {
        color: var(--gold);
        font-size: 12px;
        letter-spacing: 0.08em;
      }
      .article h1 {
        font-size: 54px;
        line-height: 1;
        letter-spacing: -0.03em;
        margin: 18px 0 0;
        text-align: center;
        text-transform: uppercase;
      }
      .last-updated-on {
        text-align: center;
        font-style: italic;
        color: var(--muted);
        margin: 12px 0 0;
        font-size: 14px;
      }
      .phero {
        margin: 28px 0 0;
        border: 2px solid var(--line);
        border-radius: 18px;
        overflow: hidden;
        aspect-ratio: 16 / 8;
        box-shadow: 6px 6px 0 rgba(0, 0, 0, 0.3);
        position: relative;
      }
      .phero img {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        border: 0;
        border-radius: 0;
        box-shadow: none;
      }
      .body {
        margin-top: 34px;
      }
      /* No hero image — tighten the gap under the headline. */
      .body.no-hero {
        margin-top: 28px;
      }
      @media (max-width: 720px) {
        .article h1 {
          font-size: 38px;
        }
      }
    </style>
  </body>
</html>
